# Keep the root build context small and the image clean (root Dockerfile only
# needs backend/). Excludes the frontend, local envs, and generated artifacts.
.git
frontend
**/node_modules
**/.next
**/.venv
**/venv
**/__pycache__
**/*.pyc
repositories
docs_storage
vector_storage
*.db
*.db-shm
*.db-wal
backend/.env
**/.env*.local
.vercel
