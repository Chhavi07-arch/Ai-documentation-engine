# ---------------------------------------------------------------------------
# AI Documentation Engine — backend environment configuration
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# --- AI provider ---
# The engine can talk to Anthropic directly OR to OpenRouter. Pick ONE key.
# NEVER put a real key here — this file is committed to git. Real keys go in a
# local `.env` (gitignored) or your host's dashboard (e.g. Render Environment).
#
# Option A — Anthropic directly (key looks like "sk-ant-..."):
#   set ANTHROPIC_API_KEY below. AI_PROVIDER=auto will detect it.
# Option B — OpenRouter (key looks like "sk-or-..."):
#   set OPENROUTER_API_KEY below.
# AI_PROVIDER: auto (default) | anthropic | openrouter
AI_PROVIDER=auto

# Anthropic API key (https://console.anthropic.com/settings/keys).
ANTHROPIC_API_KEY=sk-ant-...
# Anthropic model id (NO "anthropic/" prefix — that prefix is OpenRouter-only).
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter API key (https://openrouter.ai/keys) — only if using OpenRouter.
OPENROUTER_API_KEY=sk-or-...

# Model used for documentation generation + chat answers.
# Any OpenRouter model id works, e.g.:
#   anthropic/claude-sonnet-4-6
#   openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Embeddings power RAG retrieval. They default to a reliable, free LOCAL
# embedder so the vector store always has a consistent dimension. Chat answers
# still use the OpenRouter LLM regardless of this setting. Only set this to
# true if your provider/model reliably supports the /embeddings endpoint.
USE_OPENROUTER_EMBEDDINGS=true

# Model used when USE_OPENROUTER_EMBEDDINGS=true (OpenAI-compatible).
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=AI Documentation Engine

# SQLite database URL (SQLAlchemy format).
DATABASE_URL=sqlite:///./docengine.db

# Comma-separated list of allowed CORS origins for the frontend.
# Includes 3001 because `next dev` falls back to it when 3000 is in use.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Shared secret for the GitHub push webhook (POST /api/github/webhook). Set the
# same value here and in the GitHub repo's webhook settings ("Secret" field).
# When set, GitHub pushes trigger an incremental fetch + change detection with
# no re-clone. Leave empty to disable the webhook endpoint.
GITHUB_WEBHOOK_SECRET=

# --- Automatic change detection (background polling) ---
# When enabled, a background task periodically re-runs change detection for
# every READY repository, so stale-doc flags appear on their own (the polling
# complement to the webhook). Disabled by default — opt in here.
AUTO_DETECT_ENABLED=false
# How often the sweep runs, in seconds (floor of 10s). 300 = every 5 minutes.
AUTO_DETECT_INTERVAL_SECONDS=300
# true  → git-fetch latest first (catches GitHub pushes; resets local edits)
# false → only re-parse the local tree (catches local edits; no network)
AUTO_DETECT_SYNC_REMOTE=false

# Storage directories (relative to the repo root by default).
REPOSITORIES_DIR=../repositories
DOCS_STORAGE_DIR=../docs_storage
VECTOR_STORAGE_DIR=../vector_storage
