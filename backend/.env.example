# ---------------------------------------------------------------------------
# AI Documentation Engine — backend environment configuration
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# OpenRouter API key (https://openrouter.ai/keys). Required for AI features.
OPENROUTER_API_KEY=

# Model used for documentation generation + chat answers.
# Any OpenRouter model id works, e.g.:
#   anthropic/claude-sonnet-4-6
#   openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Embeddings power RAG retrieval. They default to a reliable, free LOCAL
# embedder so the vector store always has a consistent dimension. Chat answers
# still use the OpenRouter LLM regardless of this setting. Only set this to
# true if your provider/model reliably supports the /embeddings endpoint.
USE_OPENROUTER_EMBEDDINGS=false

# Model used when USE_OPENROUTER_EMBEDDINGS=true (OpenAI-compatible).
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional attribution headers recommended by OpenRouter.
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=AI Documentation Engine

# SQLite database URL (SQLAlchemy format).
DATABASE_URL=sqlite:///./docengine.db

# Comma-separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:3000

# Storage directories (relative to the repo root by default).
REPOSITORIES_DIR=../repositories
DOCS_STORAGE_DIR=../docs_storage
VECTOR_STORAGE_DIR=../vector_storage
